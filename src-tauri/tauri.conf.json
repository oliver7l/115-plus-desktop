{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "115+",
  "identifier": "io.github.lvzhenbo.115-plus-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "115+",
        "width": 1280,
        "minWidth": 1280,
        "height": 720,
        "minHeight": 720,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "publisher": "lvzhenbo",
    "longDescription": "115+ 是一个基于 115 网盘开放平台的开源桌面客户端",
    "shortDescription": "115+ 是一个基于 115 网盘开放平台的开源桌面客户端",
    "category": "Productivity",
    "copyright": "MIT License",
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY3OEE1QUM2M0FGNDMzOTUKUldTVk0vUTZ4bHFLOXhiMnB1MVMvS29rci9POEZuZytSVEQvOUFieGQxNmdNZ3VCYkc2Wit0U2QK",
      "endpoints": [
        "https://github.com/lvzhenbo/115-plus-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "version": "1.0.7"
}